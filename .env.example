TALI_ENABLE_TEST_SEED=1
DEEPSEEK_API_KEY=replace-with-a-local-development-key
NEMOCLAW_RUNNER_TOKEN=local-dev-token

# Local login. Replace all defaults before a production deployment.
TALI_AUTH_MODE=local
TALI_AUTH_JWT_SECRET=replace-with-a-long-random-secret
TALI_AUTH_LOCAL_USERNAME=admin
TALI_AUTH_LOCAL_PASSWORD=replace-with-a-local-password

# OIDC SSO: set TALI_AUTH_MODE=local-sso and configure the provider below.
# TALI_AUTH_OIDC_ISSUER=https://id.example.com/realms/tasklattice
# TALI_AUTH_OIDC_CLIENT_ID=tasklattice
# TALI_AUTH_OIDC_CLIENT_SECRET=
# TALI_AUTH_OIDC_REDIRECT_URI=http://localhost:8080/auth/sso/callback
# TALI_AUTH_OIDC_PROVIDER_NAME=Company SSO
# TALI_AUTH_OIDC_SCOPES=openid profile email
